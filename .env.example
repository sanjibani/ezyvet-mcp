# ezyVet credentials — get these by applying at https://www.ezyvet.com/become-a-partner
EZYVET_PARTNER_ID=your-partner-uuid
EZYVET_CLIENT_ID=your-client-id
EZYVET_CLIENT_SECRET=your-client-secret
EZYVET_SITE_UID=your-site-uuid
# Space-separated scopes your integration needs (e.g. "read-animal read-contact read-appointment read-invoice read-user")
EZYVET_SCOPE=read-animal read-contact read-appointment read-consult read-invoice read-user

# Optional override
# EZYVET_BASE_URL=https://api.ezyvet.com